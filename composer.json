{
    "name": "antimonial/antimonial",
    "type": "project",
    "description": "A PHP MVC framework where what you read is what runs.",
    "keywords": ["antimonial", "framework", "php"],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "antimonial/framework": "~0.10"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "scripts": {
        "post-create-project-cmd": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "prefer-stable": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
